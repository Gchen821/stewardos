PROJECT_NAME=StewardOS
APP_ENV=development

# Web
WEB_PORT=3000
NEXT_PUBLIC_APP_NAME=StewardOS
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-in-local-env
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=stewardos
POSTGRES_USER=steward
POSTGRES_PASSWORD=steward_local
DATABASE_URL=postgresql+psycopg://steward:steward_local@localhost:5432/stewardos

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=stewardos-dev
MINIO_USE_SSL=false
MINIO_CONSOLE_PORT=9001

# Repository storage (Agent / Skill / Tool source assets)
REPOSITORY_ROOT_PATH=./repositories
REPOSITORY_AGENTS_DIR=agents
REPOSITORY_SKILLS_DIR=skills
REPOSITORY_TOOLS_DIR=tools
REPOSITORY_AUTO_BOOTSTRAP=true

# Runtime LLM (required by current butler chat runtime)
# 当前后端对话链路优先读取这组统一变量
LLM_MODEL_ID=gpt-4.1-mini
LLM_FALLBACK_MODEL_ID=
LLM_RETRY_MAX=2
LLM_RETRY_BASE_DELAY=0.8
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_TIMEOUT=60

# Optional tools / memory provider keys (reserved)
TAVILY_API_KEY=
SERPAPI_API_KEY=
QDRANT_URL=
QDRANT_API_KEY=
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
