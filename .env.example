# Optional tools / memory provider keys (reserved)
TAVILY_API_KEY=
SERPAPI_API_KEY=
QDRANT_URL=
QDRANT_API_KEY=
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=

# MCP Tool Registry (tool manifest references these env names)
MCP_WEB_SERVER_URL=
MCP_WEB_AUTH_TOKEN=
