PROJECT_NAME=StewardOS
APP_ENV=development

# Web
WEB_PORT=3000
NEXT_PUBLIC_APP_NAME=StewardOS
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-in-local-env
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=stewardos
POSTGRES_USER=steward
POSTGRES_PASSWORD=steward_local
DATABASE_URL=postgresql+psycopg://steward:steward_local@localhost:5432/stewardos

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=stewardos-dev
MINIO_USE_SSL=false
MINIO_CONSOLE_PORT=9001

# Model Providers
DEFAULT_MODEL_PROVIDER=openai
DEFAULT_MODEL_NAME=gpt-4.1-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
OLLAMA_BASE_URL=http://localhost:11434
