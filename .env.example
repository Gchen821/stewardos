PROJECT_NAME=StewardOS
APP_ENV=development

# Web
WEB_PORT=3000
NEXT_PUBLIC_APP_NAME=StewardOS
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-in-local-env
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=stewardos
POSTGRES_USER=steward
POSTGRES_PASSWORD=steward_local
DATABASE_URL=postgresql+psycopg://steward:steward_local@localhost:5432/stewardos

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=stewardos-dev
MINIO_USE_SSL=false
MINIO_CONSOLE_PORT=9001

# Repository storage (Agent / Skill / Tool source assets)
REPOSITORY_ROOT_PATH=./repositories

# Runtime LLM (required by current butler chat runtime)
# 当前后端对话链路优先读取这组统一变量
LLM_PROVIDER=auto
LLM_MODEL=gpt-4.1-mini
LLM_MODEL_ID=gpt-4.1-mini
LLM_FALLBACK_MODEL=
LLM_FALLBACK_MODEL_ID=
LLM_RETRY_MAX=2
LLM_RETRY_BASE_DELAY=0.8
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_TIMEOUT_SECONDS=60
LLM_TIMEOUT=60

# Provider-specific LLM profiles
AUTO_LLM_MODEL=
AUTO_LLM_FALLBACK_MODEL=
AUTO_LLM_BASE_URL=
AUTO_LLM_API_KEY=
AUTO_LLM_TIMEOUT_SECONDS=

OPENAI_LLM_MODEL=
OPENAI_LLM_FALLBACK_MODEL=
OPENAI_LLM_BASE_URL=
OPENAI_API_KEY=
OPENAI_LLM_TIMEOUT_SECONDS=

MODELSCOPE_LLM_MODEL=
MODELSCOPE_LLM_FALLBACK_MODEL=
MODELSCOPE_LLM_BASE_URL=
MODELSCOPE_API_KEY=
MODELSCOPE_LLM_TIMEOUT_SECONDS=

ZHIPU_LLM_MODEL=
ZHIPU_LLM_FALLBACK_MODEL=
ZHIPU_LLM_BASE_URL=
ZHIPU_API_KEY=
ZHIPU_LLM_TIMEOUT_SECONDS=

ANTHROPIC_LLM_MODEL=
ANTHROPIC_LLM_FALLBACK_MODEL=
ANTHROPIC_LLM_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_LLM_TIMEOUT_SECONDS=

QWEN_LLM_MODEL=
QWEN_LLM_FALLBACK_MODEL=
QWEN_LLM_BASE_URL=
DASHSCOPE_API_KEY=
QWEN_LLM_TIMEOUT_SECONDS=

OLLAMA_LLM_MODEL=
OLLAMA_LLM_FALLBACK_MODEL=
OLLAMA_LLM_BASE_URL=
OLLAMA_LLM_API_KEY=
OLLAMA_LLM_TIMEOUT_SECONDS=

VLLM_LLM_MODEL=
VLLM_LLM_FALLBACK_MODEL=
VLLM_LLM_BASE_URL=
VLLM_LLM_API_KEY=
VLLM_LLM_TIMEOUT_SECONDS=

LOCAL_LLM_MODEL=
LOCAL_LLM_FALLBACK_MODEL=
LOCAL_LLM_BASE_URL=
